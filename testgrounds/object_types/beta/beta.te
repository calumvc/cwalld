policy_module(beta, 1.0.0)

########################################
#
# Declarations
#

type beta_t;
type beta_exec_t;
init_daemon_domain(beta_t, beta_exec_t)

permissive beta_t;

########################################
#
# beta local policy
#
allow beta_t self:fifo_file rw_fifo_file_perms;
allow beta_t self:unix_stream_socket create_stream_socket_perms;

files_type(beta_t)

domain_use_interactive_fds(beta_t)

files_read_etc_files(beta_t)

miscfiles_read_localization(beta_t)
