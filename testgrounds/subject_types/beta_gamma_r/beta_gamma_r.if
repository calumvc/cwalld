
## <summary>policy for beta_gamma_r</summary>

########################################
## <summary>
##	Execute beta_gamma_r_exec_t in the beta_gamma_r domain.
## </summary>
## <param name="domain">
## <summary>
##	Domain allowed to transition.
## </summary>
## </param>
#
interface(`beta_gamma_r_domtrans',`
	gen_require(`
		type beta_gamma_r_t, beta_gamma_r_exec_t;
	')

	corecmd_search_bin($1)
	domtrans_pattern($1, beta_gamma_r_exec_t, beta_gamma_r_t)
')

######################################
## <summary>
##	Execute beta_gamma_r in the caller domain.
## </summary>
## <param name="domain">
##	<summary>
##	Domain allowed access.
##	</summary>
## </param>
#
interface(`beta_gamma_r_exec',`
	gen_require(`
		type beta_gamma_r_exec_t;
	')

	corecmd_search_bin($1)
	can_exec($1, beta_gamma_r_exec_t)
')
