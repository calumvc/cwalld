policy_module(gamma_rw, 1.0.0)

########################################
#
# Declarations
#

type gamma_rw_t;
type gamma_rw_exec_t;

require {
  type gamma_t;
  type alpha_t;
  type beta_t;
  type sanitised_t;
  type user_home_t;
}

init_daemon_domain(gamma_rw_t, gamma_rw_exec_t)

########################################
#
# gamma_rw local policy
#
allow gamma_rw_t self:fifo_file rw_fifo_file_perms;
allow gamma_rw_t self:unix_stream_socket create_stream_socket_perms;

# cwalld policies
allow gamma_rw_t gamma_t:file { read write getattr open };
allow gamma_rw_t alpha_t:file { read getattr open };
allow gamma_rw_t beta_t:file { read getattr open };
allow gamma_rw_t sanitised_t:file { read getattr open };

# navigational policies
allow gamma_rw_t user_home_t:dir { search read open write add_name };
