policy_module(delta_rw_all_r, 1.0.0)

########################################
#
# Declarations
#

type delta_rw_all_r_t;
type delta_rw_all_r_exec_t;
init_daemon_domain(delta_rw_all_r_t, delta_rw_all_r_exec_t)

permissive delta_rw_all_r_t;

########################################
#
# delta_rw_all_r local policy
#
allow delta_rw_all_r_t self:fifo_file rw_fifo_file_perms;
allow delta_rw_all_r_t self:unix_stream_socket create_stream_socket_perms;

domain_use_interactive_fds(delta_rw_all_r_t)

files_read_etc_files(delta_rw_all_r_t)

miscfiles_read_localization(delta_rw_all_r_t)
