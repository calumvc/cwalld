
## <summary>policy for secret_access_final</summary>

########################################
## <summary>
##	Execute secret_access_final_exec_t in the secret_access_final domain.
## </summary>
## <param name="domain">
## <summary>
##	Domain allowed to transition.
## </summary>
## </param>
#
interface(`secret_access_final_domtrans',`
	gen_require(`
		type secret_access_final_t, secret_access_final_exec_t;
	')

	corecmd_search_bin($1)
	domtrans_pattern($1, secret_access_final_exec_t, secret_access_final_t)
')

######################################
## <summary>
##	Execute secret_access_final in the caller domain.
## </summary>
## <param name="domain">
##	<summary>
##	Domain allowed access.
##	</summary>
## </param>
#
interface(`secret_access_final_exec',`
	gen_require(`
		type secret_access_final_exec_t;
	')

	corecmd_search_bin($1)
	can_exec($1, secret_access_final_exec_t)
')
